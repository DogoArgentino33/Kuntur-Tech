# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kuntur_tech

# JWT Authentication
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_EXPIRE_DAYS=30

# Cloudinary (optional for MVP — avatar uploads will be stubbed)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (optional for MVP — emails will be logged to console)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@kuntur-tech.com

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Redis (optional for MVP — rate limiting will use in-memory)
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development
